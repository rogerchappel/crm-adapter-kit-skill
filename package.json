{
  "name": "crm-adapter-kit-skill",
  "version": "0.1.0",
  "description": "Local-first CRM adapter planning kit for agent skills with schema checks and approval notes.",
  "type": "commonjs",
  "bin": {
    "crm-adapter-kit": "bin/crm-adapter-kit.js"
  },
  "scripts": {
    "build": "node scripts/build.js",
    "check": "node --check src/index.js && node --check bin/crm-adapter-kit.js",
    "lint": "node --check src/index.js && node --check bin/crm-adapter-kit.js",
    "test": "node --test",
    "smoke": "node bin/crm-adapter-kit.js fixtures/contact-request.json",
    "package:smoke": "node scripts/package-smoke.js",
    "release:check": "npm run check && npm run build && npm test && npm run smoke && npm run package:smoke"
  },
  "keywords": [
    "agent-skill",
    "crm",
    "adapter",
    "dry-run"
  ],
  "author": "Roger Chappel",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rogerchappel/crm-adapter-kit-skill.git"
  },
  "files": [
    "bin",
    "src",
    "docs",
    "fixtures",
    "SKILL.md",
    "README.md",
    "LICENSE",
    "SECURITY.md",
    "CONTRIBUTING.md",
    "CHANGELOG.md"
  ],
  "bugs": {
    "url": "https://github.com/rogerchappel/crm-adapter-kit-skill/issues"
  },
  "homepage": "https://github.com/rogerchappel/crm-adapter-kit-skill#readme"
}
